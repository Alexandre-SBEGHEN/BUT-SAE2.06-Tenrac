    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "tenrac = pd.read_csv('./Tenrac.csv')\n",
    "grades = pd.read_csv('./Tenrac_Grade.csv')\n",
    "\n",
    "membres_par_grade = tenrac.merge(grades, on='grade_id').groupby(['grade_id', 'grade_nom']).size().reset_index(name='nb')\n",
    "membres_par_grade  = membres_par_grade .sort_values('grade_id')\n",
    "\n",
    "grade = tenrac['grade_id']\n",
    "moyenne  = grade.mean()\n",
    "mediane  = grade.median()\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.bar(membres_par_grade ['grade_nom'], membres_par_grade ['nb'], color='steelblue')\n",
    "\n",
    "plt.axhline(moyenne, color='red',    linewidth=1.5, linestyle='--', label='Moyenne (' + str(moyenne) + ')')\n",
    "plt.axhline(mediane, color='orange', linewidth=1.5, linestyle=':',  label='Mediane (' + str(mediane) + ')')\n",
    "\n",
    "plt.ylabel('Nombre de membres')\n",
    "plt.title('Repartition des membres par grade')\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
